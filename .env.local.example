# Public, build-time env vars (safe to expose in the browser).

# Google Analytics measurement id (optional).
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Cloudflare Turnstile SITE key for the contact form widget (optional).
# The matching secret goes in .dev.vars / Worker secrets as TURNSTILE_SECRET_KEY.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# Cloudflare Web Analytics beacon token (optional, privacy-first, cookieless).
# From the Cloudflare dashboard: Web Analytics -> your site -> JS snippet token.
NEXT_PUBLIC_CF_BEACON_TOKEN=""
